# .cursorignore
# AI context exclusion: files that should not be sent to Cursor's AI
# Criteria: secrets, large/noisy generated files, tool-internal dirs

# === AI tool configs (not useful as context) ===
.copilot
.kiro
.serena
apm_modules

# === Go ===
.serverless
bin
coverage
dist
vendor
output
cover.out
coverage.html

# === Large auto-generated config ===
.gitleaks.toml
.golangci.yaml

# === Lock files (large, auto-generated) ===
.terraform.lock.hcl
apm.lock.yaml
aqua-checksums.json
go.sum
mise.lock
package-lock.json
yarn.lock

# === Node ===
node_modules

# === OS / Temp ===
.DS_Store
tmp

# === Python ===
__pycache__
.Python
.venv

# === Secrets / Credentials ===
.env
.env.*
**/.env.*.local
**/.env.local
**/credentials/**
**/secrets/**
**/*.key
**/*.p12
**/*.pem
**/*.pfx

# === Terraform ===
builds
**/.terraform/*
**/.terraform.d/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfbackend
