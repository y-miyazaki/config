# .cursorignore
# AI context exclusion: files that should not be sent to Cursor's AI
# Criteria: secrets, large/noisy generated files, tool-internal dirs

# === Secrets / Credentials ===
.env
.env.*
**/.env.*.local
**/.env.local
**/credentials/**
**/secrets/**
**/*.key
**/*.p12
**/*.pem
**/*.pfx

# === AI tool configs (not useful as context) ===
.copilot
.kiro
.serena
apm_modules/

# === Terraform ===
builds
**/.terraform/*
**/.terraform.d/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfbackend

# === Go ===
bin
coverage
dist
vendor
output
.serverless
cover.out
coverage.html

# === Node ===
node_modules

# === Python ===
__pycache__
.Python
.venv

# === OS / Temp ===
.DS_Store
tmp

# === Lock files (large, auto-generated) ===
mise.lock
apm.lock.yaml
package-lock.json
yarn.lock
go.sum
.terraform.lock.hcl

# === Large auto-generated config ===
.golangci.yaml
.gitleaks.toml
aqua-checksums.json
