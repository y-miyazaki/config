  "packageRules": [
    {
      "description": "Rules: Update tool versions in .pre-commit-config.yaml",
      "matchManagers": ["custom.regex"],
      "matchFileNames": [".pre-commit-config.yaml"],
      "commitMessagePrefix": "renovate(pre-commit-config-tool-version):",
      "addLabels": ["pre-commit-config-tool-version"]
    },
    {
      "description": "Rules: Automerge patch updates for pre-commit hook versions",
      "matchManagers": ["custom.regex"],
      "matchFileNames": [".pre-commit-config.yaml"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    }
  ]
}
