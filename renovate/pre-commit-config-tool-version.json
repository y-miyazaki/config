{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "description": "CustomManager: Update pre-commit/pre-commit-hooks rev",
      "customType": "regex",
      "fileMatch": ["^\\.pre-commit-config\\.yaml$"],
      "matchStrings": [
        "repo:\\s*https://github\\.com/pre-commit/pre-commit-hooks\\s*\\n\\s*rev:\\s*[\"']?(?<currentValue>v[\\d.]+)[\"']?"
      ],
      "depNameTemplate": "pre-commit/pre-commit-hooks",
      "datasourceTemplate": "github-releases"
    },
    {
