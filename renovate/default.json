{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":label(dependencies)",
    "mergeConfidence:age-confidence-badges",
    "github>aquaproj/aqua-renovate-config#2.12.0",
    "github>y-miyazaki/config//renovate/github-actions-tool-version"
  ],
  "branchConcurrentLimit": 10,
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "minimumReleaseAge": 7,
  "timezone": "Asia/Tokyo",
  "prConcurrentLimit": 10,
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "replace",
  "packageRules": [
    {
      "description": "Rules: Add aqua label for all aqua package updates (label-only, automerge is overridden by patch rule below)",
      "matchManagers": ["regex"],
      "matchFileNames": ["aqua.yaml"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["aqua"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Automerge patch updates for aqua packages",
      "matchManagers": ["regex"],
      "matchFileNames": ["aqua.yaml"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Add aqua label for all aqua-registry updates (label-only, automerge is overridden by minor/patch rule below)",
      "matchPackageNames": ["aquaproj/aqua-registry"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["aqua"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Automerge minor/patch updates for aqua-registry",
      "matchPackageNames": ["aquaproj/aqua-registry"],
      "matchUpdateTypes": ["minor", "patch"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Update Dockerfile base images",
      "matchManagers": ["dockerfile", "docker-compose"],
      "addLabels": ["docker"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Add github-actions label for all GitHub Actions updates (label-only, automerge is overridden by patch rule below)",
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": "renovate(github-actions):",
      "addLabels": ["github-actions"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Update GitHub Actions official actions only patch automerge (optional)",
      "matchManagers": ["github-actions"],
      "matchPackagePrefixes": ["actions/"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "renovate(github-actions-official):",
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Disable self-repo GitHub Actions digest updates only in preset repository",
      "matchRepositories": ["y-miyazaki/config"],
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["y-miyazaki/config"],
      "enabled": false
    },
    {
      "description": "Rules: Add go label for all Go module updates (label-only, automerge is overridden by patch rule below)",
      "matchManagers": ["gomod"],
      "commitMessagePrefix": "renovate(go):",
      "addLabels": ["go"],
      "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Automerge patch updates for Go modules (excluding Go toolchain)",
      "matchManagers": ["gomod"],
      "excludePackageNames": ["go"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "renovate(go):",
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Update Go toolchain major/minor requires review",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["go"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "renovate(go):",
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Add npm label for all npm package updates (label-only, automerge is overridden by patch rule below)",
      "matchManagers": ["npm"],
      "addLabels": ["npm"],
      "postUpdateOptions": ["npmDedupe"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Automerge patch updates for npm packages",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Add python label for all Python package updates (label-only, automerge is overridden by patch rule below)",
      "matchManagers": ["poetry", "pip_requirements", "pipenv"],
      "commitMessagePrefix": "renovate(python):",
      "addLabels": ["python"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Automerge patch updates for Poetry and pip",
      "matchManagers": ["poetry", "pip_requirements", "pipenv"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "renovate(python):",
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Update Terraform",
      "matchManagers": ["terraform", "terraform-version"],
      "addLabels": ["terraform"],
      "postUpdateOptions": ["terraformLockFileMaintenance"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Update Terraform modules / providers grouping",
      "matchManagers": ["terraform"],
      "matchFileNames": ["**/*.tf", "**/*.tfvars"],
      "groupName": "terraform dependencies"
    },
    {
      "description": "Rules: Safe automerge only for lockfile/digest/pin updates",
      "matchUpdateTypes": ["lockFileMaintenance", "digest", "pin"],
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Dockerfile digest/pin updates require manual review (overrides the general digest/pin automerge rule above)",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["digest", "pin"],
      "automerge": false,
      "platformAutomerge": false
    }
  ]
}
