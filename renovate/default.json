{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":label(dependencies)",
    "mergeConfidence:age-confidence-badges",
    "github>aquaproj/aqua-renovate-config#2.12.0",
    "github>y-miyazaki/config//renovate/github-actions-tool-version"
  ],
  "dependencyDashboard": true,
  "timezone": "Asia/Tokyo",
  "prConcurrentLimit": 5,
  "branchConcurrentLimit": 5,
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "replace",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Rules: Update aqua packages",
      "matchManagers": ["regex"],
      "matchFileNames": ["aqua.yaml"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["aqua"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Update aqua-registry",
      "matchPackageNames": ["aquaproj/aqua-registry"],
      "matchUpdateTypes": ["minor", "patch"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["aqua", "automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Update Dockerfile base images",
      "matchManagers": ["dockerfile", "docker-compose"],
      "addLabels": ["docker"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Update GitHub Actions",
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": "renovate(github-actions):",
      "addLabels": ["github-actions"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Update GitHub Actions official actions only patch automerge (optional)",
      "matchManagers": ["github-actions"],
      "matchPackagePrefixes": ["actions/"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "renovate(github-actions-official):",
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Update Go toolchain major/minor requires review",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["go"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "renovate(go):",
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Rules: Update npm packages patch updates automerge",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Update Terraform",
      "matchManagers": ["terraform", "terraform-version"],
      "automerge": false,
      "platformAutomerge": false,
      "addLabels": ["terraform"]
    },
    {
      "description": "Rules: Update Terraform modules / providers grouping",
      "matchManagers": ["terraform"],
      "matchFileNames": ["**/*.tf", "**/*.tfvars"],
      "groupName": "terraform dependencies"
    },
    {
      "description": "Rules: Safe automerge only for lockfile/digest/pin updates",
      "matchUpdateTypes": ["lockFileMaintenance", "digest", "pin"],
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Dockerfile digest/pin updates require manual review",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["digest", "pin"],
      "automerge": false,
      "platformAutomerge": false
    }
  ]
}
