{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "github>aquaproj/aqua-renovate-config#2.12.0",
    "github>y-miyazaki/config//renovate/github-actions-tool-version",
    "mergeConfidence:age-confidence-badges"
  ],
  "timezone": "Asia/Tokyo",
  "dependencyDashboard": true,
  "prConcurrentLimit": 10,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Update aqua packages",
      "matchManagers": ["regex"],
      "matchFileNames": ["aqua.yaml"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["aqua"]
    },
    {
      "description": "Limit aqua-registry updates to reduce noise from frequent releases",
      "matchPackageNames": ["aquaproj/aqua-registry"],
      "commitMessagePrefix": "renovate(aqua):",
      "addLabels": ["aqua"]
    },
    {
      "description": "Update Dockerfile base images",
      "matchManagers": ["dockerfile"],
      "commitMessagePrefix": "renovate(docker):",
      "addLabels": ["docker"]
    },
    {
      "description": "Update GitHub Actions",
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": "renovate(github-actions):",
      "addLabels": ["github-actions"]
    },
    {
      "description": "Update Go module dependencies",
      "matchManagers": ["gomod"],
      "commitMessagePrefix": "renovate(gomod):",
      "addLabels": ["gomod"],
      "postUpdateOptions": ["gomodTidy"]
    },
    {
      "description": "Update go directive in go.mod",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "commitMessagePrefix": "renovate(gomod):",
      "addLabels": ["gomod"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Update npm packages",
      "matchManagers": ["npm"],
      "commitMessagePrefix": "renovate(npm):",
      "addLabels": ["npm"]
    },
    {
      "description": "Update Terraform providers and modules",
      "matchManagers": ["terraform"],
      "matchFileNames": ["modules/**", "terraform/**"],
      "commitMessagePrefix": "renovate(terraform):",
      "addLabels": ["terraform"]
    },
    {
      "description": "Auto-merge minor and low-risk updates except terraform",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "excludeManagers": ["terraform", "custom.regex"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "addLabels": ["automerge"]
    },
    {
      "description": "Require review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["needs-review"]
    },
    {
      "description": "Require review for go directive updates above patch",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "platformAutomerge": false
    },
    {
      "description": "Require review for terraform updates (override automerge for all update types)",
      "matchManagers": ["terraform"],
      "automerge": false,
      "platformAutomerge": false
    }
  ]
}
