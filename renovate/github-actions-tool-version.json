      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": ["golangci_lint_version:\\s*\\n\\s*default:\\s*[\"']?(?<currentValue>v[\\d.]+)[\"']?"],
      "depNameTemplate": "golangci/golangci-lint",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "CustomManager: Update govulncheck version in workflow inputs",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
