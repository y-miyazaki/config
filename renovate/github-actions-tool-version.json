{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "description": "CustomManager: Update absc version in workflow inputs (disabled: requires checksum update)",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": ["absc_version:\\s*\\n\\s*default:\\s*[\"']?(?<currentValue>v[\\d.]+)[\"']?"],
      "depNameTemplate": "y-miyazaki/absc",
      "datasourceTemplate": "github-releases",
      "enabled": false
    },
    {
      "description": "CustomManager: Update arc version in workflow inputs (disabled: requires checksum update)",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
