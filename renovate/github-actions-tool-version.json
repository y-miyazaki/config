      "depNameTemplate": "suzuki-shunsuke/ghalint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "enabled": false
    },
    {
      "description": "CustomManager: Update zizmor version in workflow inputs",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": ["zizmor_version:\\s*\\n\\s*default:\\s*[\"']?(?<currentValue>[\\d.]+)[\"']?"],
      "depNameTemplate": "woodruffw/zizmor",
