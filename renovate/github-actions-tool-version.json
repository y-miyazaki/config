      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": ["jsonnet_version:\\s*\\n\\s*default:\\s*[\"']?(?<currentValue>v[\\d.]+)[\"']?"],
      "depNameTemplate": "google/go-jsonnet",
      "datasourceTemplate": "github-releases",
      "enabled": false
    },
    {
      "description": "CustomManager: Update terraform version in workflow inputs",
      "customType": "regex",
