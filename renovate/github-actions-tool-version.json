    {
      "description": "CustomManager: Update schemaspy version in workflow inputs",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": ["schemaspy_version:\\s*\\n\\s*default:\\s*[\"']?(?<currentValue>[\\d.]+)[\"']?"],
      "depNameTemplate": "schemaspy/schemaspy",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Rules: Update tool versions in GitHub Actions workflow inputs",
      "matchManagers": ["custom.regex"],
      "matchFileNames": [".github/workflows/**"],
      "commitMessagePrefix": "renovate(github-actions-tool-version):",
      "addLabels": ["github-actions-tool-version"]
    },
    {
      "description": "Rules: Automerge custom regex manager dependencies",
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["patch"],
      "addLabels": ["automerge"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Rules: Require review for go version updates above patch",
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "platformAutomerge": false,
      "addLabels": ["needs-review"]
    }
  ]
}
