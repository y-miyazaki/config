{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@2.2.5"]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch==2025.4.7"]
    },
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-lc",
        "TOKEN=\"${GH_TOKEN:-$GITHUB_TOKEN}\"; exec uvx mcp-compressor==0.31.5 -- https://api.githubcopilot.com/mcp/ -H \"Authorization=Bearer ${TOKEN}\" --auth explicit-headers"
      ]
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "codebase-memory-mcp",
      "args": []
    },
    "lean-ctx": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "lean-ctx-bin@3.9.7"]
    }
  }
}
